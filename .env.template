# ── ingestion-pipeline/.env ───────────────────────────────────────────────────
# Copy to .env and fill in values. Never commit .env.

# Azure AI Foundry — project endpoint
# Portal: AI Foundry → your project → Overview → Project endpoint
# CLI:    az ml workspace show --name <project> --resource-group <rg> --query properties.discoveryUrl -o tsv
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://<hub>.services.ai.azure.com/api/projects/<project>

# Deployment names — Portal: AI Foundry → your project → Deployments tab
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# Light LLM for page cleaning + table serialisation (cheap + fast)
AZURE_OPENAI_LIGHT_LLM_DEPLOYMENT=gpt-4o-mini

# Azure Blob Storage
# Portal: Storage account → Overview → Storage account name (just the name, not full URL)
AZURE_STORAGE_ACCOUNT_NAME=<storage-account-name>
AZURE_STORAGE_CONTAINER_RAW=raw-documents
AZURE_STORAGE_CONTAINER_PROCESSED=processed-chunks

# Azure AI Search (same index as retrieval pipeline)
# Portal: AI Search → Overview → Url
# Portal: AI Search → Settings → Keys → Primary admin key
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=<primary-admin-key>
AZURE_SEARCH_INDEX=idx-rag
AZURE_SEARCH_SEMANTIC_CONFIG=rag-semantic-config

# Azure Service Bus
# Local dev: use connection string (SB namespace → Shared access policies → Primary connection string)
# Production: leave blank and set AZURE_SERVICE_BUS_NAMESPACE instead (keyless via Managed Identity)
AZURE_SERVICE_BUS_CONNECTION_STR=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=...
AZURE_SERVICE_BUS_NAMESPACE=<namespace>.servicebus.windows.net
SB_QUEUE_INGESTION=ingestion-tasks
SB_QUEUE_PROCESSING=processing-tasks
SB_QUEUE_EMBEDDING=embedding-tasks

# Microsoft Graph / SharePoint
# Portal: Entra ID → App registrations → your app → Overview
SHAREPOINT_TENANT_ID=<tenant-id>
SHAREPOINT_CLIENT_ID=<app-client-id>
# Portal: Entra ID → App registrations → your app → Certificates & secrets → New client secret
SHAREPOINT_CLIENT_SECRET=<client-secret>
# Random string — must match what you send when creating the webhook subscription
SHAREPOINT_WEBHOOK_SECRET=changeme-use-a-random-string
# Optional: default site to use when webhook doesn't include a site_id
SHAREPOINT_DEFAULT_SITE_ID=

# Processing tuning (defaults are fine)
CHILD_CHUNK_MAX_TOKENS=200
PARENT_CHUNK_MAX_TOKENS=1000
HEADER_FOOTER_MARGIN_PCT=0.07

# Site → domain mapping for webhook trigger
# Format: <sharepoint-site-id>:hr,<another-site-id>:legal
# Run: GET https://graph.microsoft.com/v1.0/sites/<tenant>.sharepoint.com:/sites/<site-name>
# to find your site IDs. Defaults to 'hr' if not set.
SITE_DOMAIN_MAP=

# Observability (optional — App Insights)
APPLICATIONINSIGHTS_CONNECTION_STRING=
LOG_LEVEL=INFO
